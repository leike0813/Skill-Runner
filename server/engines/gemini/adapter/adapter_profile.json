{
  "engine": "gemini",
  "provider_contract": {
    "multi_provider": false,
    "canonical_provider_id": "google"
  },
  "prompt_builder": {
    "engine_key": "gemini",
    "default_template_path": "../../../assets/templates/gemini_default.j2",
    "fallback_inline": "Please call the skill named \"{{ skill.id }}\".",
    "merge_input_if_no_parameter_schema": true,
    "params_json_source": "input_data",
    "main_prompt_source": "none",
    "main_prompt_default_template": "Execute skill {skill_id}",
    "include_input_file_name": true,
    "include_skill_dir": true
  },
  "session_codec": {
    "strategy": "json_recursive_key",
    "error_message": "SESSION_RESUME_FAILED: missing gemini session_id",
    "error_prefix": null,
    "required_type": null,
    "id_field": null,
    "recursive_key": "session_id",
    "fallback_text_finder": "find_session_id_in_text",
    "json_lines_finder": null,
    "regex_pattern": null
  },
  "attempt_workspace": {
    "workspace_subdir": ".gemini",
    "skills_subdir": "skills",
    "use_config_parent_as_workspace": true,
    "unknown_fallback": true
  },
  "config_assets": {
    "bootstrap_path": "../config/bootstrap.json",
    "default_path": "../config/default.json",
    "enforced_path": "../config/enforced.json",
    "settings_schema_path": "../schemas/gemini_settings_schema.json",
    "skill_defaults_path": "assets/gemini_settings.json"
  },
  "model_catalog": {
    "mode": "manifest",
    "manifest_path": "../models/manifest.json",
    "models_root": "../models",
    "seed_path": null
  },
  "command_defaults": {
    "start": ["--yolo"],
    "resume": ["--yolo"],
    "ui_shell": ["--sandbox", "--approval-mode", "default"]
  },
  "structured_output": {
    "mode": "noop",
    "cli_schema_strategy": "noop",
    "compat_schema_strategy": "noop",
    "prompt_contract_strategy": "canonical_summary",
    "payload_canonicalizer": "noop"
  },
  "ui_shell": {
    "command_id": "gemini-tui",
    "label": "Gemini TUI",
    "trust_bootstrap_parent": true,
    "sandbox_arg": "--sandbox",
    "retry_without_sandbox_on_early_exit": true,
    "sandbox_probe_strategy": "gemini_container",
    "sandbox_probe_message": null,
    "auth_hint_strategy": "gemini_api_key_disables_sandbox",
    "runtime_override_strategy": "gemini_ui_shell",
    "config_assets": {
      "default_path": "../config/ui_shell_default.json",
      "enforced_path": "../config/ui_shell_enforced.json",
      "settings_schema_path": "../schemas/gemini_settings_schema.json",
      "target_relpath": ".gemini/settings.json"
    }
  },
  "cli_management": {
    "package": "@google/gemini-cli",
    "binary_candidates": ["gemini", "gemini.cmd", "gemini.exe"],
    "credential_imports": [
      {
        "source": "google_accounts.json",
        "target_relpath": ".gemini/google_accounts.json",
        "import_validator": "gemini_google_accounts_json"
      },
      {
        "source": "oauth_creds.json",
        "target_relpath": ".gemini/oauth_creds.json",
        "import_validator": "gemini_oauth_creds_json"
      }
    ],
    "credential_policy": {
      "mode": "all_of_sources",
      "sources": ["google_accounts.json", "oauth_creds.json"],
      "settings_validator": null
    },
    "resume_probe": {
      "help_hints": ["--resume"],
      "dynamic_args": ["--resume", "probe-session", "--help"]
    },
    "layout": {
      "extra_dirs": [".gemini"],
      "bootstrap_target_relpath": ".gemini/settings.json",
      "bootstrap_format": "json",
      "normalize_strategy": null
    }
  },
  "parser_auth_patterns": {
    "rules": [
      {
        "id": "gemini_oauth_code_prompt_detected",
        "enabled": true,
        "priority": 950,
        "match": {
          "all": [
            {
              "field": "combined_text",
              "op": "regex",
              "value": "Please\\s+visit\\s+the\\s+following\\s+URL\\s+to\\s+authorize\\s+the\\s+application"
            },
            {
              "field": "combined_text",
              "op": "regex",
              "value": "Enter\\s+the\\s+authorization\\s+code"
            }
          ]
        }
      },
      {
        "id": "gemini_auth_method_not_configured",
        "enabled": true,
        "priority": 900,
        "match": {
          "all": [
            {
              "field": "combined_text",
              "op": "regex",
              "value": "Please set an Auth method"
            },
            {
              "field": "combined_text",
              "op": "regex",
              "value": "GEMINI_API_KEY|GOOGLE_GENAI_USE_VERTEXAI|GOOGLE_GENAI_USE_GCA"
            }
          ]
        }
      }
    ]
  },
  "parser_structured_extract": {
    "event_type": "parsed.json",
    "session_id_key": "session_id",
    "response_key": "response",
    "summary_max_chars": 220
  }
}
