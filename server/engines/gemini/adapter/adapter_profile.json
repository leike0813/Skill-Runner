{
  "engine": "gemini",
  "prompt_builder": {
    "engine_key": "gemini",
    "default_template_path": "../../../assets/templates/gemini_default.j2",
    "fallback_inline": "Please call the skill named \"{{ skill.id }}\".",
    "merge_input_if_no_parameter_schema": true,
    "params_json_source": "input_data",
    "main_prompt_source": "none",
    "main_prompt_default_template": "Execute skill {skill_id}",
    "include_input_file_name": true,
    "include_skill_dir": true
  },
  "session_codec": {
    "strategy": "json_recursive_key",
    "error_message": "SESSION_RESUME_FAILED: missing gemini session_id",
    "error_prefix": null,
    "required_type": null,
    "id_field": null,
    "recursive_key": "session_id",
    "fallback_text_finder": "find_session_id_in_text",
    "json_lines_finder": null,
    "regex_pattern": null
  },
  "attempt_workspace": {
    "workspace_subdir": ".gemini",
    "skills_subdir": "skills",
    "use_config_parent_as_workspace": true,
    "unknown_fallback": true
  },
  "config_assets": {
    "bootstrap_path": "../config/bootstrap.json",
    "default_path": "../config/default.json",
    "enforced_path": "../config/enforced.json",
    "settings_schema_path": "../schemas/gemini_settings_schema.json",
    "skill_defaults_path": "assets/gemini_settings.json"
  },
  "model_catalog": {
    "mode": "manifest",
    "manifest_path": "../models/manifest.json",
    "models_root": "../models",
    "seed_path": null
  },
  "cli_management": {
    "package": "@google/gemini-cli",
    "binary_candidates": ["gemini", "gemini.cmd", "gemini.exe"],
    "credential_imports": [
      { "source": "google_accounts.json", "target_relpath": ".gemini/google_accounts.json" },
      { "source": "oauth_creds.json", "target_relpath": ".gemini/oauth_creds.json" }
    ],
    "credential_policy": {
      "mode": "all_of_sources",
      "sources": ["google_accounts.json", "oauth_creds.json"],
      "settings_validator": null
    },
    "resume_probe": {
      "help_hints": ["--resume"],
      "dynamic_args": ["--resume", "probe-session", "--help"]
    },
    "layout": {
      "extra_dirs": [".gemini"],
      "bootstrap_target_relpath": ".gemini/settings.json",
      "bootstrap_format": "json",
      "normalize_strategy": null
    }
  }
}
