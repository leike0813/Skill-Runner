{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Qwen Code Configuration Schema",
  "type": "object",
  "properties": {
    "security": {
      "type": "object",
      "properties": {
        "auth": {
          "type": "object",
          "properties": {
            "selectedType": {
              "type": "string",
              "enum": ["qwen-oauth", "openai"]
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "enum": ["json", "stream-json", "text"]
        },
        "includePartialMessages": {
          "type": "boolean"
        }
      },
      "required": ["format"]
    },
    "model": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "modelProviders": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "baseUrl": {
              "type": "string"
            },
            "envKey": {
              "type": "string"
            }
          },
          "required": ["id", "envKey"]
        }
      }
    }
  }
}
