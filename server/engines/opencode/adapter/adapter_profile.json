{
  "engine": "opencode",
  "prompt_builder": {
    "engine_key": "opencode",
    "default_template_path": "../../../assets/templates/opencode_default.j2",
    "fallback_inline": "{{ input_prompt }}",
    "merge_input_if_no_parameter_schema": false,
    "params_json_source": "none",
    "main_prompt_source": "parameter.prompt",
    "main_prompt_default_template": "Execute skill {skill_id}",
    "include_input_file_name": false,
    "include_skill_dir": false
  },
  "session_codec": {
    "strategy": "json_lines_scan",
    "error_message": "SESSION_RESUME_FAILED: missing session id",
    "error_prefix": "SESSION_RESUME_FAILED: opencode",
    "required_type": null,
    "id_field": null,
    "recursive_key": null,
    "fallback_text_finder": null,
    "json_lines_finder": "find_session_id",
    "regex_pattern": null
  },
  "attempt_workspace": {
    "workspace_subdir": ".opencode",
    "skills_subdir": "skills",
    "use_config_parent_as_workspace": false,
    "unknown_fallback": false
  },
  "config_assets": {
    "bootstrap_path": "../config/bootstrap.json",
    "default_path": "../config/default.json",
    "enforced_path": "../config/enforced.json",
    "settings_schema_path": "../schemas/opencode_config_schema.json",
    "skill_defaults_path": "assets/opencode_config.json"
  },
  "model_catalog": {
    "mode": "runtime_probe",
    "manifest_path": null,
    "models_root": "../models",
    "seed_path": "../models/models_seed.json"
  },
  "cli_management": {
    "package": "opencode-ai",
    "binary_candidates": ["opencode", "opencode.cmd", "opencode.exe"],
    "credential_imports": [
      { "source": "auth.json", "target_relpath": ".local/share/opencode/auth.json" },
      { "source": "antigravity-accounts.json", "target_relpath": ".config/opencode/antigravity-accounts.json" }
    ],
    "credential_policy": {
      "mode": "any_of_sources",
      "sources": ["auth.json"],
      "settings_validator": null
    },
    "resume_probe": {
      "help_hints": ["--session"],
      "dynamic_args": []
    },
    "layout": {
      "extra_dirs": [
        ".opencode",
        ".config/opencode",
        ".local/share/opencode",
        ".local/state/opencode",
        ".cache/opencode"
      ],
      "bootstrap_target_relpath": ".config/opencode/opencode.json",
      "bootstrap_format": "json",
      "normalize_strategy": null
    }
  }
}
