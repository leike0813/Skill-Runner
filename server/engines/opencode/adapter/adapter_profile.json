{
  "engine": "opencode",
  "prompt_builder": {
    "engine_key": "opencode",
    "default_template_path": "../../../assets/templates/opencode_default.j2",
    "fallback_inline": "{{ input_prompt }}",
    "merge_input_if_no_parameter_schema": false,
    "params_json_source": "none",
    "main_prompt_source": "parameter.prompt",
    "main_prompt_default_template": "Execute skill {skill_id}",
    "include_input_file_name": false,
    "include_skill_dir": false
  },
  "session_codec": {
    "strategy": "json_lines_scan",
    "error_message": "SESSION_RESUME_FAILED: missing session id",
    "error_prefix": "SESSION_RESUME_FAILED: opencode",
    "required_type": null,
    "id_field": null,
    "recursive_key": null,
    "fallback_text_finder": null,
    "json_lines_finder": "find_session_id",
    "regex_pattern": null
  },
  "attempt_workspace": {
    "workspace_subdir": ".opencode",
    "skills_subdir": "skills",
    "use_config_parent_as_workspace": false,
    "unknown_fallback": false
  },
  "config_assets": {
    "bootstrap_path": "../config/bootstrap.json",
    "default_path": "../config/default.json",
    "enforced_path": "../config/enforced.json",
    "settings_schema_path": "../schemas/opencode_config_schema.json",
    "skill_defaults_path": "assets/opencode_config.json"
  },
  "model_catalog": {
    "mode": "runtime_probe",
    "manifest_path": null,
    "models_root": "../models",
    "seed_path": "../models/models_seed.json"
  },
  "command_defaults": {
    "start": ["--format", "json"],
    "resume": ["--format", "json"],
    "ui_shell": []
  },
  "ui_shell": {
    "command_id": "opencode-tui",
    "label": "OpenCode TUI",
    "trust_bootstrap_parent": false,
    "sandbox_arg": null,
    "retry_without_sandbox_on_early_exit": false,
    "sandbox_probe_strategy": "static_unsupported",
    "sandbox_probe_message": "OpenCode inline TUI runs without sandbox.",
    "auth_hint_strategy": "none",
    "runtime_override_strategy": "none",
    "config_assets": {
      "default_path": "../config/ui_shell_default.json",
      "enforced_path": "../config/ui_shell_enforced.json",
      "settings_schema_path": null,
      "target_relpath": "opencode.json"
    }
  },
  "cli_management": {
    "package": "opencode-ai",
    "binary_candidates": ["opencode", "opencode.cmd", "opencode.exe"],
    "credential_imports": [
      {
        "source": "auth.json",
        "target_relpath": ".local/share/opencode/auth.json",
        "import_validator": "opencode_auth_json"
      },
      {
        "source": "antigravity-accounts.json",
        "target_relpath": ".config/opencode/antigravity-accounts.json",
        "import_validator": "opencode_antigravity_accounts_json",
        "aliases": ["antigravity_accounts.json"]
      }
    ],
    "credential_policy": {
      "mode": "any_of_sources",
      "sources": ["auth.json"],
      "settings_validator": null
    },
    "resume_probe": {
      "help_hints": ["--session"],
      "dynamic_args": []
    },
    "layout": {
      "extra_dirs": [
        ".opencode",
        ".config/opencode",
        ".local/share/opencode",
        ".local/state/opencode",
        ".cache/opencode"
      ],
      "bootstrap_target_relpath": ".config/opencode/opencode.json",
      "bootstrap_format": "json",
      "normalize_strategy": null
    }
  },
  "parser_auth_patterns": {
    "rules": [
      {
        "id": "opencode_google_api_key_missing",
        "enabled": true,
        "priority": 1000,
        "match": {
          "all": [
            {
              "field": "extracted.error_name",
              "op": "eq",
              "value": "ProviderAuthError"
            },
            {
              "field": "extracted.provider_id",
              "op": "eq",
              "value": "google"
            },
            {
              "field": "extracted.message",
              "op": "regex",
              "value": "API key is missing"
            }
          ]
        }
      },
      {
        "id": "opencode_missing_auth_header",
        "enabled": true,
        "priority": 950,
        "match": {
          "all": [
            {
              "field": "extracted.status_code",
              "op": "eq",
              "value": 401
            },
            {
              "field": "extracted.message",
              "op": "regex",
              "value": "Missing Authentication header|Authorization.+request header|API secret key"
            }
          ]
        }
      },
      {
        "id": "opencode_invalid_api_key",
        "enabled": true,
        "priority": 940,
        "match": {
          "all": [
            {
              "field": "extracted.status_code",
              "op": "eq",
              "value": 401
            },
            {
              "field": "extracted.message",
              "op": "regex",
              "value": "Invalid API key|Invalid Authentication"
            }
          ]
        }
      },
      {
        "id": "opencode_response_error_invalid_auth",
        "enabled": true,
        "priority": 930,
        "match": {
          "all": [
            {
              "field": "extracted.response_error_type",
              "op": "in",
              "value": [
                "invalid_authentication_error",
                "authentication_error"
              ]
            }
          ]
        }
      },
      {
        "id": "opencode_token_expired",
        "enabled": true,
        "priority": 920,
        "match": {
          "all": [
            {
              "field": "extracted.status_code",
              "op": "eq",
              "value": 401
            },
            {
              "field": "extracted.message",
              "op": "regex",
              "value": "token expired or incorrect"
            }
          ]
        }
      }
    ]
  }
}
