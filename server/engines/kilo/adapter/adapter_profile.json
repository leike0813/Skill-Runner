{
  "engine": "kilo",
  "provider_contract": {
    "multi_provider": true,
    "canonical_provider_id": null
  },
  "prompt_builder": {
    "skill_invoke_line_template": "Invoke skill named {{ skill.id }}",
    "body_prefix_extra_block": "",
    "body_suffix_extra_block": ""
  },
  "session_codec": {
    "strategy": "json_lines_scan",
    "error_message": "SESSION_RESUME_FAILED: missing session id",
    "error_prefix": "SESSION_RESUME_FAILED: kilo",
    "required_type": null,
    "id_field": null,
    "recursive_key": null,
    "fallback_text_finder": null,
    "json_lines_finder": "find_session_id",
    "regex_pattern": null
  },
  "attempt_workspace": {
    "workspace_subdir": ".kilo",
    "skills_subdir": "skills",
    "use_config_parent_as_workspace": false,
    "unknown_fallback": false
  },
  "launch": {
    "cwd_strategy": "run_dir",
    "config_env_var": "KILO_CONFIG",
    "run_dir_flag": "--dir"
  },
  "config_assets": {
    "bootstrap_path": "../config/bootstrap.json",
    "default_path": "../config/default.json",
    "enforced_path": "../config/enforced.json",
    "settings_schema_path": "../schemas/kilo_config_schema.json",
    "skill_defaults_path": "assets/kilo_config.json"
  },
  "model_catalog": {
    "mode": "runtime_probe",
    "manifest_path": null,
    "models_root": "../models",
    "seed_path": "../models/models_seed.json"
  },
  "command_defaults": {
    "start": ["run", "--format", "json", "--auto"],
    "resume": ["run", "--format", "json", "--auto", "--session"],
    "ui_shell": []
  },
  "structured_output": {
    "mode": "noop",
    "cli_schema_strategy": "noop",
    "compat_schema_strategy": "noop",
    "prompt_contract_strategy": "canonical_summary",
    "payload_canonicalizer": "noop"
  },
  "ui_shell": {
    "command_id": "kilo-tui",
    "label": "Kilo Code TUI",
    "trust_bootstrap_parent": false,
    "sandbox_arg": null,
    "retry_without_sandbox_on_early_exit": false,
    "sandbox_probe_strategy": "static_unsupported",
    "sandbox_probe_message": "Kilo Code TUI runs without sandbox by default.",
    "auth_hint_strategy": "none",
    "runtime_override_strategy": "none",
    "config_assets": {
      "default_path": null,
      "enforced_path": null,
      "settings_schema_path": "../schemas/kilo_config_schema.json",
      "target_relpath": ".kilo/kilo.jsonc"
    }
  },
  "cli_management": {
    "package": "@kilocode/cli",
    "binary_candidates": [
      "kilo",
      "kilocode",
      "kilo.cmd",
      "kilocode.cmd",
      "kilo.exe",
      "kilocode.exe"
    ],
    "credential_imports": [],
    "credential_policy": {
      "mode": "any_of_sources",
      "sources": ["kilo.jsonc"],
      "settings_validator": null
    },
    "resume_probe": {
      "help_hints": ["--session"],
      "dynamic_args": []
    },
    "layout": {
      "extra_dirs": [
        ".kilo",
        ".config/kilo",
        ".local/share/kilo",
        ".local/state/kilo",
        ".cache/kilo"
      ],
      "bootstrap_target_relpath": ".config/kilo/kilo.jsonc",
      "bootstrap_format": "json",
      "normalize_strategy": null
    }
  },
  "parser_auth_patterns": {
    "rules": [
      {
        "id": "kilo_paid_model_auth_required",
        "enabled": true,
        "priority": 1000,
        "match": {
          "any": [
            {
              "field": "extracted.response_error_type",
              "op": "eq",
              "value": "PAID_MODEL_AUTH_REQUIRED"
            },
            {
              "field": "combined_text",
              "op": "regex",
              "value": "PAID_MODEL_AUTH_REQUIRED"
            }
          ]
        }
      },
      {
        "id": "kilo_gateway_not_authenticated",
        "enabled": true,
        "priority": 980,
        "match": {
          "any": [
            {
              "field": "extracted.message",
              "op": "regex",
              "value": "You need to sign in to use this model|Not authenticated with Kilo Gateway"
            },
            {
              "field": "combined_text",
              "op": "regex",
              "value": "You need to sign in to use this model|Not authenticated with Kilo Gateway"
            }
          ]
        }
      },
      {
        "id": "kilo_gateway_unauthorized",
        "enabled": true,
        "priority": 960,
        "match": {
          "all": [
            {
              "field": "extracted.status_code",
              "op": "in",
              "value": [401, 403]
            }
          ]
        }
      }
    ]
  }
}
