{
  "includeGitInstructions": false,
  "permissions": {
    "deny": [
      "AskUserQuestion"
    ],
    "defaultMode": "bypassPermissions"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "allowWrite": [
        "//tmp"
      ]
    }
  }
}
