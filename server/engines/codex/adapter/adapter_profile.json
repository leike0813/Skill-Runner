{
  "engine": "codex",
  "provider_contract": {
    "multi_provider": false,
    "canonical_provider_id": "openai"
  },
  "prompt_builder": {
    "engine_key": "codex",
    "default_template_path": "../../../assets/templates/codex_default.j2",
    "fallback_inline": "Execute skill \"{{ skill.id }}\" with inputs: {{ params_json }}",
    "merge_input_if_no_parameter_schema": true,
    "params_json_source": "combined_input_parameter",
    "main_prompt_source": "none",
    "main_prompt_default_template": "Execute skill {skill_id}",
    "include_input_file_name": false,
    "include_skill_dir": false
  },
  "session_codec": {
    "strategy": "first_json_line",
    "error_message": "SESSION_RESUME_FAILED: missing thread_id",
    "error_prefix": "SESSION_RESUME_FAILED: codex",
    "required_type": "thread.started",
    "id_field": "thread_id",
    "recursive_key": null,
    "fallback_text_finder": null,
    "json_lines_finder": null,
    "regex_pattern": null
  },
  "attempt_workspace": {
    "workspace_subdir": ".codex",
    "skills_subdir": "skills",
    "use_config_parent_as_workspace": false,
    "unknown_fallback": false
  },
  "config_assets": {
    "bootstrap_path": "../config/bootstrap.toml",
    "default_path": "../config/default.toml",
    "enforced_path": "../config/enforced.toml",
    "settings_schema_path": "../schemas/codex_profile_schema.json",
    "skill_defaults_path": "assets/codex_config.toml"
  },
  "model_catalog": {
    "mode": "manifest",
    "manifest_path": "../models/manifest.json",
    "models_root": "../models",
    "seed_path": null
  },
  "command_defaults": {
    "start": ["--skip-git-repo-check", "--json", "--full-auto", "-p", "skill-runner"],
    "resume": ["--skip-git-repo-check", "--json", "--full-auto", "-p", "skill-runner"],
    "ui_shell": [
      "--sandbox",
      "workspace-write",
      "--ask-for-approval",
      "never",
      "-c",
      "features.shell_tool=false",
      "-c",
      "features.unified_exec=false"
    ]
  },
  "ui_shell": {
    "command_id": "codex-tui",
    "label": "Codex TUI",
    "trust_bootstrap_parent": true,
    "sandbox_arg": "--sandbox",
    "retry_without_sandbox_on_early_exit": false,
    "sandbox_probe_strategy": "codex_landlock",
    "sandbox_probe_message": null,
    "auth_hint_strategy": "none",
    "runtime_override_strategy": "none",
    "config_assets": {
      "default_path": null,
      "enforced_path": null,
      "settings_schema_path": null,
      "target_relpath": null
    }
  },
  "cli_management": {
    "package": "@openai/codex",
    "binary_candidates": ["codex", "codex.cmd", "codex.exe"],
    "credential_imports": [
      {
        "source": "auth.json",
        "target_relpath": ".codex/auth.json",
        "import_validator": "codex_auth_json"
      }
    ],
    "credential_policy": {
      "mode": "all_of_sources",
      "sources": ["auth.json"],
      "settings_validator": null
    },
    "resume_probe": {
      "help_hints": ["resume"],
      "dynamic_args": ["exec", "resume", "--help"]
    },
    "layout": {
      "extra_dirs": [".codex"],
      "bootstrap_target_relpath": ".codex/config.toml",
      "bootstrap_format": "text",
      "normalize_strategy": null
    }
  },
  "parser_auth_patterns": {
    "rules": [
      {
        "id": "codex_missing_bearer_401",
        "enabled": true,
        "priority": 900,
        "match": {
          "all": [
            {
              "field": "combined_text",
              "op": "regex",
              "value": "401\\s+Unauthorized"
            },
            {
              "field": "combined_text",
              "op": "regex",
              "value": "Missing bearer or basic authentication in header"
            }
          ]
        }
      },
      {
        "id": "codex_refresh_token_reauth_required",
        "enabled": true,
        "priority": 895,
        "match": {
          "all": [
            {
              "field": "combined_text",
              "op": "regex",
              "value": "(refresh_token_reused|refresh\\s+token.*used.*generate\\s+a\\s+new\\s+access\\s+token)"
            },
            {
              "field": "combined_text",
              "op": "regex",
              "value": "(sign\\s+in\\s+again|log\\s+out\\s+and\\s+sign\\s+in\\s+again|authentication\\s+token\\s+is\\s+expired)"
            }
          ]
        }
      }
    ]
  },
  "parser_process_extract": {
    "turn_start_payload_types": ["turn.started"],
    "turn_end_payload_types": ["turn.completed"],
    "item_type_mappings": [
      {
        "item_type": "command_execution",
        "process_type": "command_execution",
        "summary_field": "command",
        "text_field": "aggregated_output",
        "classification": "command_execution"
      },
      {
        "item_type": "function_call",
        "process_type": "tool_call",
        "summary_field": "name",
        "text_field": "arguments",
        "classification": "tool_call"
      },
      {
        "item_type": "tool_call",
        "process_type": "tool_call",
        "summary_field": "name",
        "text_field": "arguments",
        "classification": "tool_call"
      }
    ]
  }
}
