{
  "engine": "iflow",
  "prompt_builder": {
    "engine_key": "iflow",
    "default_template_path": "../../../assets/templates/iflow_default.j2",
    "fallback_inline": "{{ input_prompt }}",
    "merge_input_if_no_parameter_schema": false,
    "params_json_source": "none",
    "main_prompt_source": "parameter.prompt",
    "main_prompt_default_template": "Execute skill {skill_id}",
    "include_input_file_name": false,
    "include_skill_dir": false
  },
  "session_codec": {
    "strategy": "regex_extract",
    "error_message": "SESSION_RESUME_FAILED: missing iflow session-id",
    "error_prefix": null,
    "required_type": null,
    "id_field": null,
    "recursive_key": null,
    "fallback_text_finder": null,
    "json_lines_finder": null,
    "regex_pattern": "\"session-id\"\\s*:\\s*\"([^\"]+)\""
  },
  "attempt_workspace": {
    "workspace_subdir": ".iflow",
    "skills_subdir": "skills",
    "use_config_parent_as_workspace": false,
    "unknown_fallback": false
  },
  "config_assets": {
    "bootstrap_path": "../config/bootstrap.json",
    "default_path": "../config/default.json",
    "enforced_path": "../config/enforced.json",
    "settings_schema_path": "../schemas/iflow_settings_schema.json",
    "skill_defaults_path": "assets/iflow_settings.json"
  },
  "model_catalog": {
    "mode": "manifest",
    "manifest_path": "../models/manifest.json",
    "models_root": "../models",
    "seed_path": null
  },
  "command_defaults": {
    "start": ["--yolo", "--thinking"],
    "resume": ["--yolo", "--thinking"],
    "ui_shell": []
  },
  "ui_shell": {
    "command_id": "iflow-tui",
    "label": "iFlow TUI",
    "trust_bootstrap_parent": false,
    "sandbox_arg": null,
    "retry_without_sandbox_on_early_exit": false,
    "sandbox_probe_strategy": "static_unsupported",
    "sandbox_probe_message": "iFlow inline TUI runs without sandbox. iFlow sandbox requires Docker-image execution, which is intentionally outside this inline TUI design.",
    "auth_hint_strategy": "none",
    "runtime_override_strategy": "none",
    "config_assets": {
      "default_path": "../config/ui_shell_default.json",
      "enforced_path": "../config/ui_shell_enforced.json",
      "settings_schema_path": "../schemas/iflow_settings_schema.json",
      "target_relpath": ".iflow/settings.json"
    }
  },
  "cli_management": {
    "package": "@iflow-ai/iflow-cli",
    "binary_candidates": ["iflow", "iflow.cmd", "iflow.exe"],
    "credential_imports": [
      {
        "source": "iflow_accounts.json",
        "target_relpath": ".iflow/iflow_accounts.json",
        "import_validator": "iflow_accounts_json"
      },
      {
        "source": "oauth_creds.json",
        "target_relpath": ".iflow/oauth_creds.json",
        "import_validator": "iflow_oauth_creds_json"
      }
    ],
    "credential_policy": {
      "mode": "all_of_sources",
      "sources": ["iflow_accounts.json", "oauth_creds.json"],
      "settings_validator": "iflow_oauth_settings"
    },
    "resume_probe": {
      "help_hints": ["--resume", "--continue"],
      "dynamic_args": ["--resume", "probe-session", "--help"]
    },
    "layout": {
      "extra_dirs": [".iflow"],
      "bootstrap_target_relpath": ".iflow/settings.json",
      "bootstrap_format": "json",
      "normalize_strategy": "iflow_settings_v1"
    }
  },
  "parser_auth_patterns": {
    "rules": [
      {
        "id": "iflow_server_oauth2_required",
        "enabled": true,
        "priority": 900,
        "match": {
          "all": [
            {
              "field": "combined_text",
              "op": "regex",
              "value": "SERVER_OAUTH2_REQUIRED"
            }
          ]
        }
      },
      {
        "id": "iflow_oauth_token_expired_text",
        "enabled": true,
        "priority": 800,
        "match": {
          "all": [
            {
              "field": "combined_text",
              "op": "regex",
              "value": "OAuth2.*令牌已过期|token已过期|需要重新认证|需要使用服务器OAuth2流程"
            }
          ]
        }
      }
    ]
  }
}
