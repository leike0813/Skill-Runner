{
  "engine": "codebuddy",
  "provider_contract": {
    "multi_provider": true,
    "canonical_provider_id": null,
    "selection_required": true
  },
  "prompt_builder": {
    "skill_invoke_line_template": "${{ skill.id }}",
    "body_prefix_extra_block": "",
    "body_suffix_extra_block": ""
  },
  "session_codec": {
    "strategy": "first_json_line",
    "error_message": "SESSION_RESUME_FAILED",
    "error_prefix": "SESSION_RESUME_FAILED: codebuddy",
    "required_type": null,
    "id_field": "session_id",
    "recursive_key": null,
    "fallback_text_finder": null,
    "json_lines_finder": null,
    "regex_pattern": null
  },
  "attempt_workspace": {
    "workspace_subdir": ".codebuddy",
    "skills_subdir": "skills",
    "use_config_parent_as_workspace": false,
    "unknown_fallback": false
  },
  "launch": {
    "cwd_strategy": "run_dir",
    "config_env_var": "CODEBUDDY_CONFIG_DIR",
    "run_dir_flag": null
  },
  "config_assets": {
    "bootstrap_path": "../config/bootstrap.json",
    "default_path": "../config/default.json",
    "enforced_path": "../config/enforced.json",
    "settings_schema_path": null,
    "skill_defaults_path": null
  },
  "model_catalog": {
    "mode": "runtime_probe",
    "manifest_path": null,
    "models_root": "../models",
    "seed_path": null
  },
  "command_defaults": {
    "start": ["-p", "--output-format", "stream-json", "--permission-mode", "bypassPermissions"],
    "resume": ["-p", "--output-format", "stream-json", "--permission-mode", "bypassPermissions"],
    "ui_shell": ["-p", "--output-format", "stream-json"]
  },
  "command_features": {
    "inject_output_schema_cli": true
  },
  "structured_output": {
    "mode": "compat_translate",
    "cli_schema_strategy": "inline_schema_object",
    "compat_schema_strategy": "compat_translate",
    "prompt_contract_strategy": "compat_summary",
    "payload_canonicalizer": "payload_union_object_canonicalizer",
    "result_success_strategy": "result_structured_output_field"
  },
  "ui_shell": {
    "enabled": false,
    "command_id": "codebuddy-tui",
    "label": "CodeBuddy",
    "trust_bootstrap_parent": false,
    "sandbox_arg": null,
    "retry_without_sandbox_on_early_exit": false,
    "sandbox_probe_strategy": "static_unsupported",
    "sandbox_probe_message": null,
    "auth_hint_strategy": "none",
    "runtime_override_strategy": "none",
    "config_assets": {
      "default_path": null,
      "enforced_path": null,
      "settings_schema_path": null,
      "target_relpath": null
    }
  },
  "cli_management": {
    "package": "@tencent-ai/codebuddy-code",
    "binary_candidates": ["codebuddy", "cbc", "codebuddy.cmd", "cbc.cmd"],
    "credential_imports": [],
    "credential_policy": {
      "mode": "all_of_sources",
      "sources": ["codebuddy_auth.json"],
      "settings_validator": null
    },
    "resume_probe": {
      "help_hints": ["resume"],
      "dynamic_args": []
    },
    "layout": {
      "extra_dirs": [],
      "bootstrap_target_relpath": ".codebuddy/bootstrap.json",
      "bootstrap_format": "text",
      "normalize_strategy": null
    }
  },
  "parser_auth_patterns": {
    "rules": [
      {
        "id": "codebuddy_reauth_required",
        "enabled": true,
        "priority": 900,
        "match": {
          "any": [
            {
              "field": "combined_text",
              "op": "regex",
              "value": "(?i)(401\\s+unauthorized|login required|not logged in|authentication.*(?:expired|failed)|token.*expired)"
            }
          ]
        }
      }
    ]
  }
}
