{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-runner.local/schemas/adapter_profile_schema.json",
  "title": "Adapter Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "engine",
    "prompt_builder",
    "session_codec",
    "attempt_workspace",
    "config_assets",
    "model_catalog",
    "command_defaults",
    "ui_shell",
    "cli_management",
    "parser_auth_patterns"
  ],
  "properties": {
    "engine": {
      "type": "string",
      "enum": ["codex", "gemini", "iflow", "opencode", "claude", "qwen"]
    },
    "prompt_builder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_key",
        "merge_input_if_no_parameter_schema",
        "fallback_inline",
        "params_json_source",
        "main_prompt_source",
        "main_prompt_default_template",
        "include_input_file_name",
        "include_skill_dir"
      ],
      "properties": {
        "engine_key": { "type": "string" },
        "default_template_path": { "type": ["string", "null"] },
        "fallback_inline": { "type": "string" },
        "merge_input_if_no_parameter_schema": { "type": "boolean" },
        "params_json_source": {
          "type": "string",
          "enum": ["none", "input_data", "combined_input_parameter"]
        },
        "main_prompt_source": {
          "type": "string",
          "enum": ["none", "parameter.prompt"]
        },
        "main_prompt_default_template": { "type": "string" },
        "include_input_file_name": { "type": "boolean" },
        "include_skill_dir": { "type": "boolean" }
      }
    },
    "session_codec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "error_message"],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["first_json_line", "json_recursive_key", "json_lines_scan", "regex_extract"]
        },
        "error_message": { "type": "string" },
        "error_prefix": { "type": ["string", "null"] },
        "required_type": { "type": ["string", "null"] },
        "id_field": { "type": ["string", "null"] },
        "recursive_key": { "type": ["string", "null"] },
        "fallback_text_finder": {
          "type": ["string", "null"],
          "enum": [null, "find_session_id_in_text"]
        },
        "json_lines_finder": {
          "type": ["string", "null"],
          "enum": [null, "find_session_id"]
        },
        "regex_pattern": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": { "properties": { "strategy": { "const": "first_json_line" } } },
          "then": { "required": ["error_prefix", "required_type", "id_field"] }
        },
        {
          "if": { "properties": { "strategy": { "const": "json_recursive_key" } } },
          "then": { "required": ["recursive_key"] }
        },
        {
          "if": { "properties": { "strategy": { "const": "json_lines_scan" } } },
          "then": { "required": ["error_prefix", "json_lines_finder"] }
        },
        {
          "if": { "properties": { "strategy": { "const": "regex_extract" } } },
          "then": { "required": ["regex_pattern"] }
        }
      ]
    },
    "attempt_workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_subdir",
        "skills_subdir",
        "use_config_parent_as_workspace",
        "unknown_fallback"
      ],
      "properties": {
        "workspace_subdir": { "type": "string" },
        "skills_subdir": { "type": "string" },
        "use_config_parent_as_workspace": { "type": "boolean" },
        "unknown_fallback": { "type": "boolean" }
      }
    },
    "config_assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bootstrap_path",
        "default_path",
        "enforced_path"
      ],
      "properties": {
        "bootstrap_path": { "type": "string", "minLength": 1 },
        "default_path": { "type": "string", "minLength": 1 },
        "enforced_path": { "type": "string", "minLength": 1 },
        "settings_schema_path": { "type": ["string", "null"] },
        "skill_defaults_path": { "type": ["string", "null"] }
      }
    },
    "model_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["manifest", "runtime_probe"]
        },
        "manifest_path": { "type": ["string", "null"] },
        "models_root": { "type": ["string", "null"] },
        "seed_path": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "manifest" } } },
          "then": { "required": ["manifest_path"] }
        }
      ]
    },
    "command_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "resume", "ui_shell"],
      "properties": {
        "start": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "resume": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "ui_shell": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ui_shell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "label",
        "trust_bootstrap_parent",
        "sandbox_arg",
        "retry_without_sandbox_on_early_exit",
        "sandbox_probe_strategy",
        "sandbox_probe_message",
        "auth_hint_strategy",
        "runtime_override_strategy",
        "config_assets"
      ],
      "properties": {
        "command_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "trust_bootstrap_parent": { "type": "boolean" },
        "sandbox_arg": { "type": ["string", "null"] },
        "retry_without_sandbox_on_early_exit": { "type": "boolean" },
        "sandbox_probe_strategy": {
          "type": "string",
          "enum": [
            "static_supported",
            "static_unsupported",
            "codex_landlock",
            "gemini_container"
          ]
        },
        "sandbox_probe_message": { "type": ["string", "null"] },
        "auth_hint_strategy": {
          "type": "string",
          "enum": ["none", "gemini_api_key_disables_sandbox"]
        },
        "runtime_override_strategy": {
          "type": "string",
          "enum": ["none", "gemini_ui_shell", "claude_ui_shell"]
        },
        "config_assets": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "default_path",
            "enforced_path",
            "settings_schema_path",
            "target_relpath"
          ],
          "properties": {
            "default_path": { "type": ["string", "null"] },
            "enforced_path": { "type": ["string", "null"] },
            "settings_schema_path": { "type": ["string", "null"] },
            "target_relpath": { "type": ["string", "null"] }
          }
        }
      }
    },
    "cli_management": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "binary_candidates",
        "credential_imports",
        "credential_policy",
        "resume_probe",
        "layout"
      ],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "binary_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "credential_imports": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "target_relpath"],
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "target_relpath": { "type": "string", "minLength": 1 },
              "import_validator": {
                "type": ["string", "null"],
                "enum": [
                  null,
                  "json_object",
                  "codex_auth_json",
                  "gemini_google_accounts_json",
                  "gemini_oauth_creds_json",
                  "iflow_accounts_json",
                  "iflow_oauth_creds_json",
                  "opencode_auth_json",
                  "opencode_antigravity_accounts_json",
                  "qwen_oauth_creds_json"
                ]
              },
              "aliases": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            }
          }
        },
        "credential_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "sources", "settings_validator"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["all_of_sources", "any_of_sources"]
            },
            "sources": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "settings_validator": {
              "type": ["string", "null"],
              "enum": [null, "iflow_oauth_settings"]
            }
          }
        },
        "resume_probe": {
          "type": "object",
          "additionalProperties": false,
          "required": ["help_hints", "dynamic_args"],
          "properties": {
            "help_hints": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "dynamic_args": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "layout": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "extra_dirs",
            "bootstrap_target_relpath",
            "bootstrap_format",
            "normalize_strategy"
          ],
          "properties": {
            "extra_dirs": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "bootstrap_target_relpath": { "type": "string", "minLength": 1 },
            "bootstrap_format": {
              "type": "string",
              "enum": ["json", "text"]
            },
            "normalize_strategy": {
              "type": ["string", "null"],
              "enum": [null, "iflow_settings_v1"]
            }
          }
        }
      }
    },
    "parser_auth_patterns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rules"],
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "enabled", "priority", "match"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "enabled": { "type": "boolean" },
              "priority": { "type": "integer" },
              "match": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "all": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/parser_auth_clause" }
                  },
                  "any": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/parser_auth_clause" }
                  }
                },
                "anyOf": [
                  { "required": ["all"] },
                  { "required": ["any"] }
                ]
              }
            }
          }
        }
      }
    },
    "parser_structured_extract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_type", "session_id_key", "response_key", "summary_max_chars"],
      "properties": {
        "event_type": { "type": "string", "minLength": 1 },
        "session_id_key": { "type": "string", "minLength": 1 },
        "response_key": { "type": "string", "minLength": 1 },
        "summary_max_chars": { "type": "integer", "minimum": 32, "maximum": 2000 }
      }
    },
    "parser_process_extract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turn_start_payload_types", "turn_end_payload_types", "item_type_mappings"],
      "properties": {
        "turn_start_payload_types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "turn_end_payload_types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "item_type_mappings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["item_type", "process_type"],
            "properties": {
              "item_type": { "type": "string", "minLength": 1 },
              "process_type": {
                "type": "string",
                "enum": ["reasoning", "tool_call", "command_execution"]
              },
              "summary_field": { "type": ["string", "null"] },
              "text_field": { "type": ["string", "null"] },
              "classification": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "parser_auth_clause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "op", "value"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "op": {
          "enum": ["eq", "in", "regex", "contains", "gte"]
        },
        "value": {}
      }
    }
  }
}
