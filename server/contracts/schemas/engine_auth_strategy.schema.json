{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engine_auth_strategy.schema.json",
  "title": "Engine Auth Strategy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "engines"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "engines": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codex",
        "gemini",
        "opencode",
        "claude",
        "qwen"
      ],
      "properties": {
        "codex": {
          "$ref": "#/$defs/engine_scoped_engine"
        },
        "gemini": {
          "$ref": "#/$defs/engine_scoped_engine"
        },
        "opencode": {
          "$ref": "#/$defs/provider_aware_engine"
        },
        "claude": {
          "$ref": "#/$defs/engine_scoped_engine"
        },
        "qwen": {
          "$ref": "#/$defs/provider_aware_engine"
        }
      }
    }
  },
  "$defs": {
    "runtime_auth_method": {
      "type": "string",
      "enum": [
        "callback",
        "auth_code_or_url",
        "api_key",
        "custom_provider"
      ]
    },
    "conversation_auth_method": {
      "type": "string",
      "enum": [
        "callback",
        "device_auth",
        "auth_code_or_url",
        "import",
        "api_key",
        "custom_provider"
      ]
    },
    "transport": {
      "type": "string",
      "enum": [
        "oauth_proxy",
        "cli_delegate",
        "provider_config"
      ]
    },
    "driver_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_method",
        "execution_mode"
      ],
      "properties": {
        "start_method": {
          "type": "string",
          "minLength": 1
        },
        "execution_mode": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "session_behavior_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input_required": {
          "type": "boolean"
        },
        "polling_start": {
          "type": "string",
          "enum": [
            "manual_submit",
            "immediate"
          ]
        }
      }
    },
    "transport_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "methods",
        "driver"
      ],
      "properties": {
        "methods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/runtime_auth_method"
          }
        },
        "high_risk_methods": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/runtime_auth_method"
          }
        },
        "driver": {
          "$ref": "#/$defs/driver_policy"
        },
        "session_behavior": {
          "$ref": "#/$defs/session_behavior_policy"
        }
      }
    },
    "transport_map": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oauth_proxy": {
          "$ref": "#/$defs/transport_policy"
        },
        "cli_delegate": {
          "$ref": "#/$defs/transport_policy"
        },
        "provider_config": {
          "$ref": "#/$defs/transport_policy"
        }
      },
      "minProperties": 1
    },
    "engine_scoped_engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transports",
        "in_conversation"
      ],
      "properties": {
        "transports": {
          "$ref": "#/$defs/transport_map"
        },
        "in_conversation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "transport",
            "methods"
          ],
          "properties": {
            "transport": {
              "$ref": "#/$defs/transport"
            },
            "methods": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/conversation_auth_method"
              }
            }
          }
        }
      }
    },
    "provider_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transports",
        "in_conversation"
      ],
      "properties": {
        "transports": {
          "$ref": "#/$defs/transport_map"
        },
        "in_conversation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "methods"
          ],
          "properties": {
            "methods": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/conversation_auth_method"
              }
            }
          }
        }
      }
    },
    "provider_aware_engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in_conversation",
        "providers"
      ],
      "properties": {
        "in_conversation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "transport"
          ],
          "properties": {
            "transport": {
              "$ref": "#/$defs/transport"
            }
          }
        },
        "providers": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/provider_policy"
          }
        }
      }
    }
  }
}
