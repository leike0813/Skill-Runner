{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "engine", "rules"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "engine": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "enabled", "priority", "match", "classify"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer"
          },
          "match": {
            "type": "object",
            "properties": {
              "all": {
                "type": "array",
                "items": { "$ref": "#/definitions/clause" }
              },
              "any": {
                "type": "array",
                "items": { "$ref": "#/definitions/clause" }
              }
            },
            "additionalProperties": false,
            "anyOf": [
              { "required": ["all"] },
              { "required": ["any"] }
            ]
          },
          "classify": {
            "type": "object",
            "required": ["classification", "subcategory", "confidence"],
            "properties": {
              "classification": {
                "enum": ["auth_required", "not_auth", "unknown"]
              },
              "subcategory": {
                "type": ["string", "null"],
                "enum": [
                  "oauth_reauth",
                  "api_key_missing",
                  "invalid_api_key",
                  "auth_expired",
                  "unknown_auth",
                  null
                ]
              },
              "confidence": {
                "enum": ["high", "medium", "low"]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "clause": {
      "type": "object",
      "required": ["field", "op", "value"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "op": {
          "enum": ["eq", "in", "regex", "contains", "gte"]
        },
        "value": {}
      },
      "additionalProperties": false
    }
  }
}
