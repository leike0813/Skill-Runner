{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-runner.local/schemas/protocol_golden_fixture.schema.json",
  "title": "Protocol Golden Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "layer",
    "engine",
    "capability_requirements",
    "inputs",
    "expected",
    "normalization",
    "source",
    "source_run_id"
  ],
  "properties": {
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "enum": [
        "parser_only",
        "protocol_core",
        "outcome_core"
      ]
    },
    "capture_mode": {
      "type": "string",
      "enum": [
        "single_attempt",
        "whole_run"
      ]
    },
    "engine": {
      "type": "string",
      "minLength": 1
    },
    "capability_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inputs": {
      "type": "object"
    },
    "expected": {
      "type": "object"
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ignore_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "attempt_number",
          "status_hint"
        ],
        "properties": {
          "attempt_number": {
            "type": "integer",
            "minimum": 1
          },
          "status_hint": {
            "type": "string",
            "minLength": 1
          },
          "stdout": {
            "type": "string"
          },
          "stderr": {
            "type": "string"
          },
          "pty_output": {
            "type": "string"
          },
          "completion": {
            "type": "object"
          },
          "pending_context": {
            "type": "object"
          },
          "meta_file": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "run_artifacts": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "result_file": {
          "type": "string",
          "minLength": 1
        },
        "state_file": {
          "type": "string",
          "minLength": 1
        },
        "meta_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fcmp_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "events_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source": {
      "type": "string",
      "enum": [
        "captured_run",
        "derived_from_sample",
        "synthetic_minimal"
      ]
    },
    "source_run_id": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
